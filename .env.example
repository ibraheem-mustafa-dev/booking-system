# =============================================================================
# Booking System — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Small Giants Studio"

# --- Supabase ---
# For development: use Supabase Cloud (free tier) at https://supabase.com
# For production: self-hosted Supabase via Docker Compose on VPS
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (direct connection for Drizzle migrations) ---
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/booking_system

# --- Security ---
# AES-256-GCM key for encrypting OAuth tokens at rest (64 hex chars / 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# --- Error Tracking (Sentry) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Outlook OAuth (Azure AD) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# --- Zoom OAuth ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="Small Giants Studio <bookings@smallgiantsstudio.co.uk>"

# --- Redis (for BullMQ job queue) ---
REDIS_URL=redis://localhost:6379

# --- AI Services ---
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Stripe (Phase 2) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
